# TLS Point Cloud Volume Estimation - Environment Variables
# Префикс: TPCVE (TLS Point Cloud Volume Estimation)
# Скопируйте в .env и настройте под свои нужды

# Путь к --list-файлу (train) по умолчанию
TPCVE_LIST=datasets/yanco-2019-wheat-pcd/data/train_list.txt
# Путь к --list-test-файлу (test)
TPCVE_LIST_TEST=datasets/yanco-2019-wheat-pcd/data/test_list.txt
# База для путей из --list (используется в batch.py / analyze.py)
TPCVE_BASE_DIR=datasets/yanco-2019-wheat-pcd/data/Yanco_TC_2019_HI-pcd

# Единицы измерения координат (auto, m, cm, mm)
# По умолчанию: auto (автоопределение)
# TPCVE_UNITS=auto

# Фильтр стадии роста (Z31/Z65) по подстроке в пути облака
# TPCVE_STAGE=Z65

# Перевернуть ось Z (1/true/yes для включения)
# По умолчанию: не переворачивать
# TPCVE_FLIP_Z=false

# Коэффициент прореживания облака (0 = не прореживать)
# Значение > 0 применяет voxel downsampling с указанным размером вокселя
# По умолчанию: 0 (без прореживания)
# TPCVE_DOWNSAMPLE=0

# Параметр std_ratio для Statistical Outlier Removal (batch.py)
# По умолчанию: 2.0
# TPCVE_SOR_STD_RATIO=2.0

# Делить биомассу Z65 на 2 (для приведения к Z31)
# По умолчанию: true
# TPCVE_DIV2_Z65=false

# Порог высоты для отделения земли от растительности (м)
# По умолчанию: 0.04
# TPCVE_HEIGHT_THRESHOLD=0.04

# Минимальное расстояние от начала координат (м)
# Точки ближе этого расстояния будут удалены (0 = не фильтровать)
# По умолчанию: 0 (без фильтрации)
# TPCVE_MIN_RANGE=0
